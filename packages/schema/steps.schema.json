{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Demoscope Step File",
  "type": "object",
  "required": ["meta", "steps"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["baseUrl", "viewport"],
      "properties": {
        "title": { "type": "string" },
        "baseUrl": { "type": "string" },
        "viewport": {
          "type": "object",
          "required": ["width", "height"],
          "properties": {
            "width": { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 }
          }
        },
        "defaultWait": { "type": "integer", "minimum": 0 }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action"],
        "properties": {
          "id": { "type": "string" },
          "action": {
            "type": "string",
            "enum": ["navigate", "click", "type", "scroll", "wait", "hover", "select", "keypress"]
          },
          "annotation": { "type": "string" },
          "wait": { "type": "integer", "minimum": 0 },
          "zoom": {
            "type": "object",
            "required": ["level"],
            "properties": {
              "level": { "type": "number", "minimum": 1 },
              "padding": { "type": "integer", "minimum": 0 }
            }
          },
          "highlight": { "type": "boolean" },
          "selector": { "type": "string" },
          "url": { "type": "string" },
          "text": { "type": "string" },
          "typeDelay": { "type": "integer", "minimum": 0 },
          "deltaY": { "type": "number" },
          "duration": { "type": "integer", "minimum": 0 },
          "value": { "type": "string" },
          "key": { "type": "string" }
        }
      }
    }
  }
}
